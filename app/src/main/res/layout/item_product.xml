<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="product"
            type="woowacourse.shopping.domain.product.Product" />

        <variable
            name="productClickListener"
            type="woowacourse.shopping.view.product.ProductViewHolder.ProductClickListener" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:onClick="@{() -> productClickListener.onProductClick(product)}">

        <ImageView
            android:id="@+id/productImage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/gray_a"
            android:contentDescription="@{product.name}"
            app:imageUrl="@{product.imageUrl}"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/product_image_example" />

        <ImageView
            android:id="@+id/productPlusQuantityButtonDefault"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:onClick="@{() -> productClickListener.onPlusShoppingCartClick(product)}"
            android:src="@drawable/btn_product_plus"
            app:layout_constraintBottom_toBottomOf="@id/productImage"
            app:layout_constraintEnd_toEndOf="@id/productImage" />

        <TextView
            android:id="@+id/productMinusQuantityButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="14dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/background_product_minus_quantity_button"
            android:gravity="center"
            android:onClick="@{() -> productClickListener.onMinusShoppingCartClick(product)}"
            android:text="@string/product_minus_quantity_button"
            android:textColor="@color/gray_5"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/productImage"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@id/productQuantity"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/productQuantity"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:background="@drawable/background_product_quantity"
            android:gravity="center"
            android:textColor="@color/gray_5"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/productMinusQuantityButton"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@id/productPlusQuantityButton"
            app:layout_constraintStart_toEndOf="@id/productMinusQuantityButton"
            app:layout_constraintTop_toTopOf="@id/productPlusQuantityButton"
            tools:text="3" />

        <TextView
            android:id="@+id/productPlusQuantityButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/background_product_plus_quantity_button"
            android:gravity="center"
            android:onClick="@{() -> productClickListener.onPlusShoppingCartClick(product)}"
            android:text="@string/product_plus_quantity_button"
            android:textColor="@color/gray_5"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/productPlusQuantityButton"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/productQuantity"
            app:layout_constraintTop_toTopOf="@id/productPlusQuantityButton" />

        <TextView
            android:id="@+id/productName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="6dp"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@{product.name}"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/productImage"
            tools:text="PET보틀-정사각형어쩌구저쩌구" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@{@string/product_price_format(product.price)}"
            android:textColor="@color/gray_5"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/productName"
            app:layout_constraintStart_toStartOf="@id/productName"
            app:layout_constraintTop_toBottomOf="@id/productName"
            tools:text="10,000원" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
