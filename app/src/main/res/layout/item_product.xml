<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="vm"
            type="woowacourse.shopping.view.product.main.ProductViewModel" />

        <variable
            name="position"
            type="int" />

        <variable
            name="product"
            type="woowacourse.shopping.domain.Product" />

        <variable
            name="onAddCart"
            type="kotlin.jvm.functions.Function2" />

        <variable
            name="onSelectedProduct"
            type="kotlin.jvm.functions.Function1" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:onClick="@{() -> onSelectedProduct.invoke(product)}">

        <ImageView
            android:id="@+id/iv_product"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            app:imageUrl="@{product.imageUrl}"
            app:layout_constraintBottom_toTopOf="@+id/tv_product_name"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_delete" />

        <include
            android:id="@+id/i_product_count_control"
            layout="@layout/product_count"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="@{vm.isAddCart ? View.VISIBLE : View.GONE}"
            app:layout_constraintBottom_toBottomOf="@id/iv_product"
            app:layout_constraintEnd_toEndOf="@id/iv_product"
            app:layout_constraintStart_toStartOf="@id/iv_product" />

        <TextView
            android:id="@+id/tv_product_plus_cart"
            style="@style/ProductAddCartStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_product_plus_cart"
            android:onClick="@{() -> onAddCart.invoke(product, position)}"
            android:text="@string/product_add_cart"
            android:visibility="@{vm.isAddCart ? View.GONE : View.VISIBLE}"
            app:layout_constraintBottom_toBottomOf="@id/iv_product"
            app:layout_constraintEnd_toEndOf="@id/iv_product" />

        <TextView
            android:id="@+id/tv_product_name"
            style="@style/ProductTitleStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="6dp"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@{product.name}"
            app:layout_constraintStart_toStartOf="@id/iv_product"
            app:layout_constraintTop_toBottomOf="@id/iv_product" />

        <TextView
            android:id="@+id/tv_product_price"
            style="@style/ProductPriceStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{@string/product_price(product.price)}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/tv_product_name"
            app:layout_constraintTop_toBottomOf="@id/tv_product_name" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
