<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="position"
            type="int" />

        <variable
            name="cartItem"
            type="woowacourse.shopping.domain.CartItem" />

        <variable
            name="onAddCart"
            type="kotlin.jvm.functions.Function3" />

        <variable
            name="onSelectedProduct"
            type="kotlin.jvm.functions.Function1" />

        <variable
            name="decrease"
            type="kotlin.jvm.functions.Function1" />

        <variable
            name="increase"
            type="kotlin.jvm.functions.Function1" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:onClick="@{() -> onSelectedProduct.invoke(cartItem.product)}">

        <ImageView
            android:id="@+id/iv_product"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            app:imageUrl="@{cartItem.product.imageUrl}"
            app:layout_constraintBottom_toTopOf="@+id/tv_product_name"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_delete" />

        <include
            android:id="@+id/i_product_count_control"
            layout="@layout/component_product_count_no_vm"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginHorizontal="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cartItem="@{cartItem}"
            app:decrease="@{decrease}"
            app:increase="@{increase}"
            app:layout_constraintBottom_toBottomOf="@id/iv_product"
            app:layout_constraintEnd_toEndOf="@id/iv_product"
            app:layout_constraintStart_toStartOf="@id/iv_product"
            app:productCount="@{cartItem.count}" />

        <TextView
            android:id="@+id/tv_product_plus_cart"
            style="@style/ProductAddCartStyle"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_product_plus_cart"
            android:onClick="@{(view) -> onAddCart.invoke(cartItem, position, view)}"
            android:text="@string/product_add_cart"

            app:layout_constraintBottom_toBottomOf="@id/iv_product"
            app:layout_constraintEnd_toEndOf="@id/iv_product" />

        <TextView
            android:id="@+id/tv_product_name"
            style="@style/ProductTitleStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="6dp"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@{cartItem.product.name}"
            app:layout_constraintStart_toStartOf="@id/iv_product"
            app:layout_constraintTop_toBottomOf="@id/iv_product" />

        <TextView
            android:id="@+id/tv_product_price"
            style="@style/ProductPriceStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{@string/product_price(cartItem.product.price)}"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/tv_product_name"
            app:layout_constraintTop_toBottomOf="@id/tv_product_name" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
