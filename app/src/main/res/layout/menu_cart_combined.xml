<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />


        <variable
            name="viewModel"
            type="woowacourse.shopping.presentation.viewmodel.products.ProductsViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/linearLayout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_cart_icon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:onClick="navigateToCart"
            android:padding="2dp"
            android:src="@drawable/ic_products_cart"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />


        <ImageView
            android:id="@+id/iv_cart_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:layout_marginRight="14dp"
            android:src="@drawable/bg_products_circle_mint"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iv_cart_icon"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="@{viewModel.cart.empty ? View.INVISIBLE : View.VISIBLE}"/>

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:text="@{String.valueOf(viewModel.cart.size())}"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="@+id/iv_cart_icon"
            app:layout_constraintEnd_toEndOf="@+id/iv_cart_badge"
            app:layout_constraintStart_toEndOf="@+id/iv_cart_icon"
            android:visibility="@{viewModel.cart.empty ? View.INVISIBLE : View.VISIBLE}"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
