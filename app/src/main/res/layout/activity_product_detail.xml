<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="viewModel"
            type="woowacourse.shopping.view.productdetail.ProductDetailViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/product_detail_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/gray_5"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/close_image_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:backgroundTint="@android:color/transparent"
                android:contentDescription="@null"
                android:src="@drawable/ic_close" />

        </androidx.appcompat.widget.Toolbar>

        <ImageView
            android:id="@+id/iv_product_image"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            app:imageUrl="@{viewModel.selectedProduct.product.imageUrl}"
            app:layout_constraintTop_toBottomOf="@id/product_detail_toolbar" />

        <TextView
            android:id="@+id/product_detail_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            android:text="@{viewModel.selectedProduct.product.title}"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="[든든] 동원 스위트콘"
            app:layout_constraintTop_toBottomOf="@id/iv_product_image" />

        <View
            android:id="@+id/line"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#AAAAAA"
            android:layout_marginVertical="17dp"
            app:layout_constraintTop_toBottomOf="@id/product_detail_title" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/product_price_quantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="18dp"
            app:layout_constraintTop_toBottomOf="@id/line"

            >

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@{String.format(@string/product_price_format,viewModel.selectedProduct.product.price)}"
                android:textAlignment="textStart"
                android:textColor="@color/black"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="99,800원" />

            <include
                android:id="@+id/quantity_selector"
                layout="@layout/item_product_quantity_selector"
                android:layout_width="126dp"
                android:layout_height="42dp"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/recent_product_info"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="vertical"
            android:background="@drawable/border_1_dp"
            android:paddingVertical="16dp"
            android:paddingHorizontal="18dp"
            android:layout_marginHorizontal="18dp"
            android:layout_marginVertical="9dp"
            app:layout_constraintTop_toBottomOf="@+id/product_price_quantity">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/last_product_text"
                android:textSize="12sp"
                android:textColor="@color/aqua_green" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@{viewModel.lastProductTitle}"
                android:textSize="18sp"
                tools:text="PET보틀-정사각형(500ml)" />

        </LinearLayout>


        <TextView
            android:id="@+id/tv_add_to_cart"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/mint_green"
            android:clickable="true"
            android:gravity="center"
            android:onClick="@{()-> viewModel.onAddToCartClicked()}"
            android:text="@string/button_add_to_cart"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>