<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="product"
            type="woowacourse.shopping.domain.product.Product" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="4dp">
        
        <ImageView
            android:id="@+id/iv_recent_image"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:contentDescription="@string/product_description"
            android:scaleType="centerCrop"
            app:setImageWithGlide="@{product.imageUrl}"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_recent_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxEms="10"
            android:singleLine="true"
            android:text="@{product.name}"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="4dp"
            android:layout_marginTop="7dp"
            app:layout_constraintTop_toBottomOf="@id/iv_recent_image"
            app:layout_constraintStart_toStartOf="@id/iv_recent_image"
            app:layout_constraintEnd_toEndOf="@id/iv_recent_image"
            tools:text="PET보틀-정사각형(500ml)))))))))))))))))))))))))))" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
