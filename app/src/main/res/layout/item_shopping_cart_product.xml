<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="cartItem"
            type="woowacourse.shopping.domain.CartItem" />

        <variable
            name="handler"
            type="woowacourse.shopping.view.shoppingcart.ShoppingCartEventHandler" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:background="@drawable/background_item_shopping_cart">

        <LinearLayout
            android:id="@+id/ll_item_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginVertical="10dp"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_shopping_cart_item"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@{cartItem.name}"
                android:textColor="@color/gray"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="[든든] 동원 스위트콘" />

            <ImageView
                android:id="@+id/iv_remove_item_product_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:onClick="@{() -> handler.onRemoveCartItem(cartItem)}"
                android:src="@drawable/icon_close"
                app:tint="#AAAAAA" />
        </LinearLayout>

        <ImageView
            android:id="@+id/iv_shopping_cart_image"
            productImage="@{cartItem.imageUrl}"
            android:layout_width="150dp"
            android:layout_height="80dp"
            android:layout_marginVertical="20dp"
            android:layout_marginStart="15dp"
            android:scaleType="centerCrop"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_item_header"
            tools:src="@drawable/sample_product_detail_image" />

        <LinearLayout
            android:id="@+id/ll_quantity_wrapper"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginEnd="15dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_shopping_cart_image">

            <TextView
                android:id="@+id/tv_decrease_quantity"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/background_layout_product_counter_decrease"
                android:gravity="center"
                android:text="@string/button_minus"
                android:textColor="@color/gray"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_quantity"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@color/white"
                android:gravity="center"
                android:textColor="@color/gray"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="1" />

            <TextView
                android:id="@+id/tv_increase_quantity"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/background_layout_product_counter_increase"
                android:gravity="center"
                android:text="@string/button_plus"
                android:textColor="@color/gray"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_price"
            priceWithFormat="@{cartItem.price}"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:textColor="@color/gray"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@id/iv_shopping_cart_image"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="99,800원" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
